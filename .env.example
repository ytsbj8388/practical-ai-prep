# Anthropic Claude API key — used by tag.py (Phase 2) for vocab/turn-taking/domain annotations
ANTHROPIC_API_KEY=sk-ant-...

# Hugging Face access token — required by pyannote diarization in align.py
#
# You MUST also accept the model licenses on Hugging Face with the same account:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
#
# Without license acceptance, diarization downloads will 401 even with a valid token.
HF_TOKEN=hf_...
